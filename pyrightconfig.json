{
  "venvPath": ".",
  "venv": ".venv",
  "extraPaths": [
    "packages/shared/src",
    "packages/pixel-mcp/src",
    "packages/pixel-mcp-ml/src"
  ],
  "include": [
    "packages/*/src",
    "packages/*/tests"
  ],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "**/.venv",
    "**/dist",
    "**/build"
  ],
  "reportMissingImports": "error",
  "reportMissingTypeStubs": "warning",
  "typeCheckingMode": "basic"
}
